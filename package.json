{
  "name": "@silkweave/meet",
  "version": "2.1.1",
  "description": "Silkweave Google Meet MCP & CLI",
  "author": "Tobias Strebitzer <tobias.strebitzer@atomic.bi>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/silkweave/meet.git"
  },
  "type": "module",
  "main": "./build/index.mjs",
  "types": "./build/index.d.mts",
  "bin": {
    "meet": "./build/mcp.mjs",
    "meet-cli": "./build/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./build/index.mjs",
      "types": "./build/index.d.mts"
    },
    "./cli": {
      "import": "./build/cli.mjs",
      "types": "./build/cli.d.mts"
    },
    "./mcp": {
      "import": "./build/mcp.mjs",
      "types": "./build/mcp.d.mts"
    }
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 tsdown",
    "prepack": "pnpm clean && pnpm build",
    "watch": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "check": "pnpm lint && pnpm typecheck",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^5.3.0",
    "@orama/orama": "^3.1.18",
    "@orama/plugin-data-persistence": "^3.1.18",
    "@silkweave/cli": "^1.7.0",
    "@silkweave/core": "^1.7.0",
    "@silkweave/mcp": "^1.7.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "openai": "^6.34.0",
    "xmlbuilder2": "^4.0.3",
    "yaml": "^2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.0.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "resolutions": {
    "zod": "4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
